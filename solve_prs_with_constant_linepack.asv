% V = pi * D^2 / 4 * L;
% V_std = V * (avrgPrs / (Prs_stp/1e5)) * (T_stp / T_gas) / Z_pipe;
% linepackEnergy_min = V_std * newGCV / 1e12; % TJ
% avaliable_linepack = linepack - linepackEnergy_min;
